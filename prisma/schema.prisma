generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  name         String
  passwordHash String
  role         String         @default("USER")
  timeZone     String
  gender       String?
  birthDate    String?
  city         String?
  phone        String?
  photoPath    String?
  source       String?
  createdAt    DateTime       @default(now())
  bookings     Booking[]
  courses      ClientCourse[]
}

model Booking {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt         DateTime
  endsAt           DateTime
  clientTimeZone   String
  type             String    @default("DIAGNOSTIC")
  diagnosticNumber Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  status           String    @default("ACTIVE")
  cancelledAt      DateTime?
  rescheduledAt    DateTime?

  @@index([startsAt])
  @@index([startsAt, endsAt])
  @@index([status, startsAt])
  @@index([type, startsAt])
  @@index([diagnosticNumber])
}

model ClientCourse {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  remaining Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model DaySchedule {
  id                  Int      @id @default(autoincrement())
  dateKey             String   @unique
  slotDurationMinutes Int      @default(120)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HiddenSlot {
  id        Int      @id @default(autoincrement())
  startsAt  DateTime @unique
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model CustomSlot {
  id        Int      @id @default(autoincrement())
  startsAt  DateTime @unique
  endsAt    DateTime
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model DayOff {
  id        Int      @id @default(autoincrement())
  dateKey   String   @unique
  createdAt DateTime @default(now())
}
