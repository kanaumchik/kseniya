generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/xeniia.db"
}

model User {
  id           String         @id @default(cuid())
  publicId     Int?
  email        String         @unique
  name         String
  passwordHash String
  role         String         @default("USER")
  timeZone     String
  gender       String?
  birthDate    String?
  city         String?
  phone        String?
  photoPath    String?
  source       String?
  createdAt    DateTime       @default(now())
  bookings     Booking[]
  courses      ClientCourse[]

  @@index([publicId])
}

model Booking {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt         DateTime
  endsAt           DateTime
  clientTimeZone   String
  type             String    @default("DIAGNOSTIC")
  diagnosticNumber Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  status           String    @default("ACTIVE")
  cancelledAt      DateTime?
  rescheduledAt    DateTime?

  @@index([startsAt])
  @@index([startsAt, endsAt])
  @@index([status, startsAt])
  @@index([type, startsAt])
  @@index([diagnosticNumber])
}

model ClientCourse {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  remaining Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model DaySchedule {
  id                  String   @id @default(cuid())
  dateKey             String   @unique
  slotDurationMinutes Int      @default(120)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HiddenSlot {
  id        String   @id @default(cuid())
  startsAt  DateTime @unique
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model CustomSlot {
  id        String   @id @default(cuid())
  startsAt  DateTime @unique
  endsAt    DateTime
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model DayOff {
  id        String   @id @default(cuid())
  dateKey   String   @unique
  createdAt DateTime @default(now())
}
