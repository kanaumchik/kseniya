generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  name         String
  passwordHash String
  role         String         @default("USER")
  timeZone     String
  gender       String?
  birthDate    String?
  city         String?
  phone        String?
  photoPath    String?
  source       String?
  createdAt    DateTime       @default(now())
  bookings     Booking[]
  courses      ClientCourse[]
  consentEvents ConsentEvent[]
  analyticsEvents AnalyticsEvent[]
}

model Booking {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startsAt         DateTime
  endsAt           DateTime
  clientTimeZone   String
  type             String    @default("DIAGNOSTIC")
  packageTitle     String?
  diagnosticNumber Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  status           String    @default("ACTIVE")
  cancelledAt      DateTime?
  rescheduledAt    DateTime?
  consentEvents    ConsentEvent[]

  @@index([startsAt])
  @@index([startsAt, endsAt])
  @@index([status, startsAt])
  @@index([type, startsAt])
  @@index([diagnosticNumber])
}

model ClientCourse {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  remaining Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model DaySchedule {
  id                  Int      @id @default(autoincrement())
  dateKey             String   @unique
  slotDurationMinutes Int      @default(120)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HiddenSlot {
  id        Int      @id @default(autoincrement())
  startsAt  DateTime @unique
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model CustomSlot {
  id        Int      @id @default(autoincrement())
  startsAt  DateTime @unique
  endsAt    DateTime
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}

model DayOff {
  id        Int      @id @default(autoincrement())
  dateKey   String   @unique
  createdAt DateTime @default(now())
}

model LegalDocumentVersion {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentCode  String         @map("document_code")
  title         String
  version       String
  publishedAt   DateTime       @map("published_at") @db.Timestamptz(6)
  url           String
  contentText   String         @map("content_text")
  contentSha256 String         @map("content_sha256")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  consentEvents ConsentEvent[]

  @@unique([documentCode, version, contentSha256])
  @@index([documentCode, isActive])
  @@map("legal_document_versions")
}

model ConsentEvent {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             Int?                  @map("user_id")
  user               User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousId        String?               @map("anonymous_id")
  stage              String
  consentType        String                @map("consent_type")
  action             String
  documentVersionId  String?               @map("document_version_id") @db.Uuid
  documentVersionRef LegalDocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)
  documentCode       String?               @map("document_code")
  documentVersion    String?               @map("document_version")
  documentSha256     String?               @map("document_sha256")
  documentUrl        String?               @map("document_url")
  bookingKind        String?               @map("booking_kind")
  serviceId          String?               @map("service_id")
  appointmentId      Int?                  @map("appointment_id")
  appointment        Booking?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  cookieChoice       String?               @map("cookie_choice")
  cookiesNecessary   Boolean?              @map("cookies_necessary")
  cookiesAnalytics   Boolean?              @map("cookies_analytics")
  cookiesMarketing   Boolean?              @map("cookies_marketing")
  checkboxLabel      String?               @map("checkbox_label")
  buttonLabel        String?               @map("button_label")
  pageUrl            String                @map("page_url")
  referrer           String?
  ipAddressHash      String?               @map("ip_address_hash")
  userAgent          String?               @map("user_agent")
  acceptLanguage     String?               @map("accept_language")
  timezone           String?
  sessionIdHash      String?               @map("session_id_hash")
  requestId          String?               @map("request_id")
  eventPayload       Json                  @default("{}") @map("event_payload")
  occurredAt         DateTime              @default(now()) @map("occurred_at") @db.Timestamptz(6)
  previousEventHash  String?               @map("previous_event_hash")
  eventHash          String                @unique @map("event_hash")
  serverSignature    String                @map("server_signature")
  signatureAlgorithm String                @default("HMAC-SHA256") @map("signature_algorithm")
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, occurredAt])
  @@index([anonymousId, occurredAt])
  @@index([stage, occurredAt])
  @@index([consentType, occurredAt])
  @@index([appointmentId])
  @@map("consent_events")
}

model AnalyticsEvent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType        String   @map("event_type")
  eventName        String   @map("event_name")
  elementId        String?  @map("element_id")
  elementText      String?  @map("element_text")
  elementGroup     String?  @map("element_group")
  pageUrl          String   @map("page_url")
  path             String
  referrer         String?
  userId           Int?     @map("user_id")
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonymousId      String?  @map("anonymous_id")
  sessionId        String?  @map("session_id")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  acceptLanguage   String?  @map("accept_language")
  timezone         String?
  consentAnalytics Boolean  @default(false) @map("consent_analytics")
  durationMs       Int?     @map("duration_ms")
  eventPayload     Json     @default("{}") @map("event_payload")
  occurredAt       DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([occurredAt])
  @@index([eventType, occurredAt])
  @@index([eventName, occurredAt])
  @@index([elementId, occurredAt])
  @@index([userId, occurredAt])
  @@index([path, occurredAt])
  @@map("analytics_events")
}

model AnalyticsDailyAggregate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dateKey         String   @map("date_key")
  eventType       String   @map("event_type")
  eventName       String   @map("event_name")
  elementId       String?  @map("element_id")
  elementText     String?  @map("element_text")
  elementGroup    String?  @map("element_group")
  path            String
  count           Int      @default(0)
  totalDurationMs Int      @default(0) @map("total_duration_ms")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([dateKey])
  @@index([eventType, dateKey])
  @@index([eventName, dateKey])
  @@map("analytics_daily_aggregates")
}
